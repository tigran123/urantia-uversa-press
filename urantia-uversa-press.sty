\newcommand{\bibpaperdisplay}[2]{%
   \begin{center}%
   \ifnum #1=1
       \titlefont\partheaderfontsize\partitxt\\[2ex]
       \parttextfontsize\partiup\\[3ex]
   \fi
   \ifnum #1=32
       \titlefont\partheaderfontsize\partiitxt\\[2ex]
       \parttextfontsize\partiiup\\[3ex]
   \fi
   \ifnum #1=57
       \titlefont\partheaderfontsize\partiiitxt\\[2ex]
       \parttextfontsize\partiiiup\\[3ex]
   \fi
   \ifnum #1=120
       \titlefont\partheaderfontsize\partivtxt\\[2ex]
       \parttextfontsize\partivup\\[3ex]
   \fi
   \ifnum #1>0\bibpaperfont\uppercase{\papertxt}\nobreakspace#1\\[1ex]\fi
   \bibpapertitlefont\uppercase{#2}\\%
   \end{center}%

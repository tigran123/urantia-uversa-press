%\protected\def\print@vssup#1{\makebox[0.2em][r]{\@textsuperscript{\fontsize{7}{7}\selectfont#1}}\kern0.2em\relax}
% top-aligned paragraph numbers at cap-height
\protected\def\print@vssup#1{%
  \begingroup
    % typeset and measure the small numeral
    \sbox0{\fontsize{6}{6}\selectfont #1}%
    % cap height of current text font (use H as a robust proxy)
    \dimen@=\fontcharht\font`H\relax
    \makebox[0.2em][r]{%
      \raisebox{\dimexpr\dimen@-\ht0\relax}[\dimen@][0pt]{\copy0}%
    }%
    \kern0.2em\relax
  \endgroup
}
\protected\def\printvssuper#1{%
  \begingroup
    % typeset and measure the small numeral
    \sbox0{\fontsize{6}{6}\selectfont #1}%
    % cap height of current text font (use H as a robust proxy)
    \dimen@=\fontcharht\font`H\relax
    \makebox[0.2em][r]{%
      \raisebox{\dimexpr\dimen@-\ht0\relax}[\dimen@][0pt]{\copy0}%
    }%
    \kern0.05em\relax
  \endgroup
}


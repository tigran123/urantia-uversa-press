    \stepcounter{secnum}%
       \begin{multicols}{2}[\begin{center}\parbox{\columnwidth}{\mdseries\centering\textsc{\sctitlefontsize\thesecnum.\bibnobreakspace #1}}\end{center}][5\baselineskip]
}

\newcommand*{\usectiontwo}[2]{%
\def\secname{#2}%
    \end{multicols}%
    \fancyhead[CE]{\bibheadfont\authorname}%

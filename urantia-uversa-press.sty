    \stepcounter{secnum}%
       \begin{multicols}{2}[\begin{center}\parbox{\columnwidth}{\mdseries\centering\titlefontsize #1.\bibnobreakspace\textsc{\sctitlefontsize #2}}\end{center}][5\baselineskip]
